# apps/gatherend-gateway | copy to .env and fill in values

# Port Caddy listens on (set automatically if you use Railway)
PORT=

# Secret sent by Cloudflare as X-Origin-Verify header to block direct access
CF_ORIGIN_SECRET=

# Internal URL of the Express service (e.g. express.railway.internal:3001 for Railway)
# If you don't use Railway then set this to localhost:3001 and make sure to run the Express server on port 3001
EXPRESS_UPSTREAM=

# Internal URL of the Next.js service (e.g. web.railway.internal:3000)
# If you don't use Railway then set this to localhost:3000 and make sure to run the Next.js server on port 3000
NEXT_UPSTREAM=
