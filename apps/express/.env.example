# apps/express | copy to .env and fill in values

# Port the server listens on
PORT=
# development or production, this is extremely important, if you use a development instance you can have vulnerabilities,
# make sure to set this to production when deploying and to development when running locally
NODE_ENV=

# Postgres connection string
DATABASE_URL=

# Redis connection string
REDIS_URL=

# Must match the value set in gatherend-web
BETTER_AUTH_SECRET=
# Full URL of the Next.js app (e.g. https://gatherend.com)
BETTER_AUTH_URL=

# Cloudflare R2 — main bucket (community/profile images)
# For now the repo just supports S3 api
# R2 is the supported storage, but in the future I plan to make it more storage-agnostic
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# Cloudflare R2 — attachments bucket (message uploads)
ATTACHMENTS_BUCKET_NAME=
ATTACHMENTS_BASE_URL=
# Signed URL TTL in seconds 
ATTACHMENTS_URL_TTL_SECONDS=
# Round expiry to this interval to improve CDN cache hit rate
ATTACHMENTS_URL_EXP_ROUND_SECONDS=

# Self-hosted imgproxy instance
IMGPROXY_URL=
IMGPROXY_KEY=
IMGPROXY_SALT=

# NudeNet — NSFW image moderation
NUDENET_URL=
NUDENET_API_KEY=

# Allowed origins for CORS, use https
FRONTEND_URL=
# Internal Railway URL (private network, no TLS required)
# If you don't use Railway, set this to the same value as FRONTEND_URL but with http and the port your frontend runs on (e.g. http://localhost:3000) 
RAILWAY_PRIVATE_URL=

# Secret shared with gatherend-web for internal service-to-service calls
INTERNAL_API_SECRET=

# Comma-separated hostnames allowed as media sources (SSRF protection)
MEDIA_ALLOWED_HOSTNAMES=
