# apps/gatherend-web | copy to .env and fill in values

# Random secret for signing sessions — generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=
# Full URL of this app, used by Better Auth for callbacks (e.g. https://gatherend.com)
BETTER_AUTH_URL=

# Postgres connection string
DATABASE_URL=

# Redis connection string
REDIS_URL=

# Cloudflare R2, main bucket (community/profile images)
# For now the repo just supports S3 api
# R2 is the supported storage, but in the future I plan to make it more storage-agnostic
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# Cloudflare R2 — attachments bucket (message uploads)
ATTACHMENTS_BUCKET_NAME=
ATTACHMENTS_BASE_URL=

# Self-hosted imgproxy instance
IMGPROXY_URL=
# Generate key/salt with: openssl rand -hex 32 
IMGPROXY_KEY=
IMGPROXY_SALT=

# LiveKit server credentials
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# SMTP for transactional email (any provider: Gmail, Postmark, SES, Resend, Mailpit...)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
# Optional display name for the sender
SMTP_FROM_NAME=

# Postmark webhook (optional, only if using Postmark for bounce/suppression tracking)
POSTMARK_WEBHOOK_SECRET=

# OAuth — Discord
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# OAuth — Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Comma-separated profile/user IDs with admin access
ADMIN_PROFILE_IDS=
ADMIN_USER_IDS=

# Secret for authenticating cron job requests
CRON_SECRET=

# Canonical public URL (used in sitemap, metadata)
SITE_URL=

# Build-time public vars (must be set as ARG in Dockerfile) 

# URL of the Express API, accessible from the browser
NEXT_PUBLIC_API_URL=
# URL of the Socket.IO server
NEXT_PUBLIC_SOCKET_URL=
# WebSocket URL of the LiveKit server
NEXT_PUBLIC_LIVEKIT_URL=
# Public CDN URL served through imgproxy
NEXT_PUBLIC_CDN_URL=
# Direct imgproxy base URL
NEXT_PUBLIC_IMGPROXY_URL=
# R2 domain used to detect R2 URLs client-side (e.g. pub-xxx.r2.dev)
NEXT_PUBLIC_R2_DOMAIN=
# Better Auth base URL accessible from the browser
NEXT_PUBLIC_BETTER_AUTH_URL=
# Dicebear URL for avatar generation
NEXT_PUBLIC_DICEBEAR_URL=