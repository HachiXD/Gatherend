{
  "expo": {
    "name": "Gatherend",
    "slug": "Gatherend",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/GATHEREND_SQUARE_RELLENADO.png",
    "scheme": "gatherendmobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#3D6E58",
        "foregroundImage": "./assets/images/GATHEREND_OUTLINE_RELLENADO_V1_BOTAS_ICONO.png",

        "monochromeImage": "./assets/images/GATHEREND_OUTLINE_RELLENADO_V1_BOTAS_ICONO_MONOCHROME.png"
      },

      "predictiveBackGestureEnabled": false,
      "package": "com.gatherend.app"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "@livekit/react-native-expo-plugin",
        {
          "cameraPermission": "Allow Gatherend to access your camera",
          "microphonePermission": "Allow Gatherend to access your microphone"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/GATHEREND_OUTLINE_RELLENADO_V1_BOTAS.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#3D6E58",
          "dark": {
            "backgroundColor": "#3D6E58"
          }
        }
      ],
      "expo-secure-store",
      "expo-font",
      "expo-image",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
