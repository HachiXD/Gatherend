# --- Core ---
POSTGRES_USER=gatherend
POSTGRES_PASSWORD=
POSTGRES_DB=gatherend
REDIS_PASSWORD=

# --- Auth ---
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=https://yourdomain.com
INTERNAL_API_SECRET=

# --- Cloudflare ---
# Shared secret between Cloudflare and Caddy (X-Origin-Verify header)
CF_ORIGIN_SECRET=

# --- S3-compatible storage ---
# For Cloudflare R2: leave S3_ENDPOINT empty, set STORAGE_ACCOUNT_ID
# For MinIO / generic: set S3_ENDPOINT, leave STORAGE_ACCOUNT_ID empty
S3_ENDPOINT=
STORAGE_ACCOUNT_ID=
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_BUCKET_NAME=
STORAGE_PUBLIC_URL=

# Private attachments bucket
ATTACHMENTS_BUCKET_NAME=
ATTACHMENTS_BASE_URL=
# HMAC secret for signing attachment URLs — generate with: openssl rand -hex 32
ATTACHMENTS_HMAC_KEY=
ATTACHMENTS_URL_TTL_SECONDS=
ATTACHMENTS_URL_EXP_ROUND_SECONDS=

# --- imgproxy (external) ---
IMGPROXY_URL=
IMGPROXY_KEY=
IMGPROXY_SALT=

# --- NudeNet (external, optional) ---
NUDENET_URL=
NUDENET_API_KEY=

# --- LiveKit (external) ---
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# --- SMTP ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_FROM_NAME=

# --- Postmark webhook (optional) ---
POSTMARK_WEBHOOK_SECRET=

# --- OAuth ---
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Admin ---
ADMIN_PROFILE_IDS=
ADMIN_USER_IDS=
CRON_SECRET=

# --- URLs ---
FRONTEND_URL=https://yourdomain.com
SITE_URL=https://yourdomain.com
MEDIA_ALLOWED_HOSTNAMES=
# Internal URL for Next.js SSR → Express (set automatically in docker-compose)
# SOCKET_SERVER_URL=http://express:3001

# --- Build-time NEXT_PUBLIC_* (baked into client JS at build time) ---
NEXT_PUBLIC_API_URL=https://yourdomain.com/api/r2
NEXT_PUBLIC_SOCKET_URL=https://yourdomain.com/api/r2
NEXT_PUBLIC_LIVEKIT_URL=
NEXT_PUBLIC_CDN_URL=
NEXT_PUBLIC_IMGPROXY_URL=
NEXT_PUBLIC_STORAGE_DOMAIN=
NEXT_PUBLIC_BETTER_AUTH_URL=https://yourdomain.com
NEXT_PUBLIC_DICEBEAR_URL=
