# --- Domains ---
APP_DOMAIN=yourdomain.com
IMAGES_DOMAIN=img.yourdomain.com
AVATARS_DOMAIN=avatars.yourdomain.com
MODERATION_DOMAIN=moderation.yourdomain.com

# --- Content Moderation ---
# Secret key to authenticate requests to the moderation endpoint
CONTENT_MODERATION_API_KEY=

# --- imgproxy ---
# Must match IMGPROXY_KEY and IMGPROXY_SALT in the main server .env
IMGPROXY_KEY=
IMGPROXY_SALT=

# --- MinIO (optional, profile: minio) ---
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=

# --- LiveKit (optional, profile: livekit) ---
# Only needed if running LiveKit on this server
LIVEKIT_DOMAIN=media.yourdomain.com
LIVEKIT_TURN_DOMAIN=turn.yourdomain.com
